{{/* Runs once at `chezmoi init`. Prompts for the machine's trust level, derives  */}}
{{/* feature flags from it, and writes them to ~/.config/chezmoi/chezmoi.toml —    */}}
{{/* machine-local, never committed. These OVERRIDE .chezmoidata.toml's defaults.  */}}
{{- $choices := list "personal-primary" "personal-secondary" "company" "client-restricted" -}}
{{- $trust := promptChoiceOnce . "trust_level" "Machine trust level" $choices "client-restricted" -}}

{{- /* feature flags derived from trust level */ -}}
{{- $secrets := or (eq $trust "personal-primary") (eq $trust "personal-secondary") (eq $trust "company") -}}
{{- $ssh := eq $trust "personal-primary" -}}
{{- /* every initialized machine gets the minimal, client-safe base… */ -}}
{{- $brew := true -}}
{{- /* …but only non-client tiers get the heavy standard/company tail. */ -}}
{{- $brewFull := ne $trust "client-restricted" -}}
{{- $work := or (eq $trust "company") (eq $trust "client-restricted") -}}

{{- /* git identity — stored in machine-local config, never committed */ -}}
{{- $gitName  := promptStringOnce . "git_name"  "Git user name"  "" -}}
{{- $gitEmail := promptStringOnce . "git_email" "Git user email" "" -}}

{{- /* opt-in Obsidian AI vault / Claude-memory bundle — independent of trust level */ -}}
{{- $obsidian := promptBoolOnce . "obsidian_ai_vault" "Enable Obsidian AI vault bundle" false -}}
{{- $vault := "" -}}
{{- if $obsidian -}}
{{-   $vault = promptStringOnce . "obsidian_vault" "Obsidian vault absolute path" "" -}}
{{- end -}}

[data]
    trust_level = {{ $trust | quote }}

[data.features]
    secrets       = {{ $secrets }}
    ssh_keys      = {{ $ssh }}
    homebrew      = {{ $brew }}
    homebrew_full = {{ $brewFull }}
    work_git      = {{ $work }}

[data.git]
    name  = {{ $gitName | quote }}
    email = {{ $gitEmail | quote }}

[data.obsidian]
    ai_vault = {{ $obsidian }}
    vault    = {{ $vault | quote }}
