#!/usr/bin/env bash
{{- if .features.homebrew }}
# Re-runs whenever this rendered content changes (run_onchange_).
# The {{ `{{ include }}` }} directives below embed Brewfile.base + the shared PATH
# snippet verbatim into the rendered script, so editing either changes this
# script's hash and the bundle re-fires — no separate hash line needed.
# brew bundle is idempotent: already-installed packages are skipped.
set -euo pipefail
{{ include ".chezmoitemplates/apply-log.sh" }}
_SCRIPT="homebrew"

# First apply: install-deps installed brew in a separate process whose PATH
# didn't reach here. Re-source brew's shellenv so the base bundle runs now.
{{ include ".chezmoitemplates/path-bootstrap.sh" -}}

command -v brew >/dev/null 2>&1 || { echo "brew not found — skipping bundle"; exit 0; }

# Escape hatch: skip the (slow) package install while everything else still
# applies. Used by scripts/local-validate.sh to keep validation fast, and handy
# for `DOTFILES_SKIP_BREW_BUNDLE=1 chezmoi apply` when only config changed.
if [ "${DOTFILES_SKIP_BREW_BUNDLE:-0}" = "1" ]; then
  echo "DOTFILES_SKIP_BREW_BUNDLE=1 — skipping brew bundle."
  exit 0
fi

# brew bundle SILENTLY SKIPS a formula/cask with no bottle for this platform and
# still exits 0. So we install from a temp Brewfile, then `brew bundle check` it
# to catch anything that did not actually land. Base misses are critical (they
# are the client-safe guarantee); standard-tail misses are best-effort.
base_file=""; tail_file=""
trap 'rm -f "${base_file}" "${tail_file}"' EXIT
missing_critical=0
missing_optional=0

bundle_and_verify() {
  local label="$1" file="$2" critical="$3" out
  echo "Installing Homebrew ${label}…"
  brew bundle --file="${file}"
  if out="$(brew bundle check --file="${file}" --verbose 2>&1)"; then
    echo "  ${label}: all entries installed ✓"
  else
    echo "⚠ ${label}: the following are NOT installed (likely no bottle for this platform):" >&2
    printf '%s\n' "${out}" | sed 's/^/    /' >&2
    if [ "${critical}" = "1" ]; then missing_critical=1; else missing_optional=1; fi
  fi
}

base_file="$(mktemp)"
cat > "${base_file}" <<'BREWFILE'
{{ include ".chezmoitemplates/Brewfile.base" -}}
BREWFILE
{{- if eq .chezmoi.os "darwin" }}
# bash-completion conflicts with util-linux on linuxbrew; macOS-only.
cat >> "${base_file}" <<'BREWFILE_MACOS'
brew "bash-completion"
BREWFILE_MACOS
{{- end }}
bundle_and_verify "base" "${base_file}" 1
{{- if .features.homebrew_full }}

tail_file="$(mktemp)"
cat > "${tail_file}" <<'BREWFILE'
# taps
tap "go-task/tap"
tap "derailed/k9s"

# containers
brew "colima"
brew "docker"
brew "docker-buildx"
brew "docker-compose"
brew "docker-credential-helper"
brew "crane"

# kubernetes
brew "kubernetes-cli"
brew "helm"
brew "helmfile"
brew "kustomize"
brew "k9s"
brew "stern"

# cloud
brew "awscli"
brew "azure-cli"

# editors / docs
brew "helix"
brew "glow"
brew "pandoc"

# python tooling (runtimes via mise; these are standalone tools)
brew "uv"
brew "pipx"

# misc dev util
brew "act"
brew "ghorg"
brew "git-filter-repo"
brew "go-task/tap/go-task"
brew "xh"
brew "watch"
brew "zstd"

# media
brew "ffmpeg"
brew "imagemagick"
brew "fontconfig"
{{- if eq .chezmoi.os "darwin" }}

# casks (macOS only) — nerd fonts handled cross-platform by 40-fonts script
cask "iterm2"
cask "obsidian"
cask "wezterm"
cask "rectangle"
{{- end }}
{{- if eq .trust_level "company" }}

# company tier (work tooling)
brew "maven"
{{-   if eq .chezmoi.os "darwin" }}
cask "p4"
cask "eclipse-ide"
{{-   end }}
{{- end }}
BREWFILE
bundle_and_verify "standard tail" "${tail_file}" 0
{{- end }}

if [ "${missing_optional}" = "1" ]; then
  echo "⚠ Some standard-tail packages are missing (no bottle here) — best-effort, continuing." >&2
  log_warn "${_SCRIPT}" "some homebrew_full packages missing (no bottle for this platform)"
fi
if [ "${missing_critical}" = "1" ]; then
  echo "✗ Minimal base is incomplete — the client-safe guarantee is not met on this machine." >&2
  log_fail "${_SCRIPT}" "base packages missing — client-safe guarantee not met"
{{- if ne .trust_level "client-restricted" }}
  exit 1
{{- end }}
else
  log_pass "${_SCRIPT}" "all base packages installed"
fi

echo "brew bundle complete."
{{- end }}
