#!/usr/bin/env bash
{{- if .features.homebrew }}
# Re-runs whenever this rendered content changes (run_onchange_).
# The {{ `{{ include }}` }} below embeds Brewfile.base verbatim into the rendered
# script, so editing the base changes this script's hash and the bundle re-fires
# — no separate hash line needed.
# brew bundle is idempotent: already-installed packages are skipped.
set -euo pipefail

command -v brew >/dev/null 2>&1 || { echo "brew not found — skipping bundle"; exit 0; }

# ── minimal base (every initialized tier, incl client-restricted) ────────────
echo "Installing Homebrew base…"
brew bundle --file=/dev/stdin <<'BREWFILE'
{{ include ".chezmoitemplates/Brewfile.base" -}}
BREWFILE
{{- if .features.homebrew_full }}

# ── standard tail (personal / company tiers) ─────────────────────────────────
echo "Installing Homebrew standard tail…"
brew bundle --file=/dev/stdin <<'BREWFILE'
# taps
tap "go-task/tap"
tap "derailed/k9s"

# containers
brew "colima"
brew "docker"
brew "docker-buildx"
brew "docker-compose"
brew "docker-credential-helper"
brew "crane"

# kubernetes
brew "kubernetes-cli"
brew "helm"
brew "helmfile"
brew "kustomize"
brew "k9s"
brew "stern"

# cloud
brew "awscli"
brew "azure-cli"

# editors / docs
brew "helix"
brew "glow"
brew "pandoc"

# python tooling (runtimes via mise; these are standalone tools)
brew "uv"
brew "pipx"

# misc dev util
brew "act"
brew "ghorg"
brew "git-filter-repo"
brew "go-task/tap/go-task"
brew "xh"
brew "watch"
brew "zstd"

# media
brew "ffmpeg"
brew "imagemagick"
brew "fontconfig"
{{- if eq .chezmoi.os "darwin" }}

# casks (macOS only)
cask "font-hack-nerd-font"
cask "wezterm"
cask "rectangle"
{{- end }}
{{- if eq .trust_level "company" }}

# company tier (work tooling)
brew "maven"
{{-   if eq .chezmoi.os "darwin" }}
cask "p4"
cask "eclipse-ide"
{{-   end }}
{{- end }}
BREWFILE
{{- end }}

echo "brew bundle complete."
{{- end }}
